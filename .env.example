# ─────────────────────────────────────────────
# MediaForensics Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME=MediaForensics
APP_ENV=development           # development | production
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=true

# ── MongoDB ───────────────────────────────────
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mediaforensics

# ── Redis (Celery task queue) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── File Storage ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif,mp4,mov,avi,mkv

# ── ML Model ──────────────────────────────────
# Download XceptionNet weights from HuggingFace:
# https://huggingface.co/selimsef/dfdc_deepfake_challenge
MODEL_PATH=./ml/weights/xception_best.pth
YOLO_MODEL=yolov8n-face.pt
DEVICE=cpu                    # cpu | cuda | mps

# ── JWT Auth ──────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440       # 24 hours

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_UPLOADS_PER_MINUTE=10
